{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "DevTool",
    "version": "0.0.3"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "clipboard": {
        "all": true,
        "readText": true,
        "writeText": true
      },
      "dialog": {
        "all": true,
        "open": true,
        "save": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "scope": [
          "$APPDATA/*",
          "$RESOURCE/*"
        ]
      },
      "process": {
        "relaunch": true
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/DianaSensei/developer-desktop-utils/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFQjFGRDU1QUUzQTEzRDMKUldUVEV6cXVWZjJ4SGhCVm03YmdSUVN4VVZhQyt6bU0yakhRY3k5eUFpU1JHOXgvbTRoT1pSaFgK"
    },
    "bundle": {
      "active": true,
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico",
        "icons/icon.icns",
        "icons/icon.png"
      ],
      "identifier": "com.devtool.app",
      "targets": [
        "app",
        "dmg",
        "msi",
        "nsis",
        "appimage",
        "deb"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "DevTool",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  }
}